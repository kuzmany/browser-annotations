#!/usr/bin/env bash
# bh-annotate — inject the annotation overlay into a Chrome tab over CDP.
# No browser-harness needed: talks straight to any Chrome started with
# --remote-debugging-port. Auto re-injects on reload; dedups its registration.
#
#   bh-annotate                         # attach to the most recent page
#   bh-annotate --url localhost:3000    # pin to a tab by URL substring
#   bh-annotate --cdp http://localhost:9222
#
# Endpoint:  --cdp  ->  $CDP_URL  ->  $BU_CDP_WS  ->  http://localhost:9222
# Then mark up the page and export with `bh-apply`.
set -euo pipefail
SELF_DIR="$(cd "$(dirname "$(readlink -f "$0")")" && pwd)"
ROOT="$(cd "$SELF_DIR/.." && pwd)"

JS_FILE="${BH_ANNOTATE_JS:-}"
if [ -z "$JS_FILE" ]; then
    for c in "$ROOT/overlay/bh-annotate.js" "$HOME/.bh-workspace/bh-annotate.js"; do
        [ -f "$c" ] && JS_FILE="$c" && break
    done
fi
[ -f "$JS_FILE" ] || { echo "bh-annotate: overlay JS not found (set BH_ANNOTATE_JS)" >&2; exit 1; }

exec python3 "$ROOT/lib/cdp.py" inject --js-file "$JS_FILE" "$@"
