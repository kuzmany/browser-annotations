#!/usr/bin/env bash
# browser-apply (alias: bh-apply) — read annotations from a Chrome tab over CDP and write them as
# markdown to ./.annotations/notes.md for your AI agent to apply.
# No browser-harness needed.
#
#   browser-apply                            # -> ./.annotations/notes.md
#   browser-apply --url localhost:3000       # pin to a tab by URL substring
#   browser-apply --out /tmp/feedback.md     # custom path
#   browser-apply --json                     # raw JSON to stdout, no file
#
# Endpoint:  --cdp  ->  $CDP_URL  ->  $BU_CDP_WS  ->  http://localhost:9222
set -euo pipefail
SELF_DIR="$(cd "$(dirname "$(readlink -f "$0")")" && pwd)"
ROOT="$(cd "$SELF_DIR/.." && pwd)"

exec python3 "$ROOT/lib/cdp.py" pull "$@"
